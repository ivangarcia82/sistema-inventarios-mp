// prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  warehouses Warehouse[]
  products   Product[]
  users      User[]
  colectas   Colecta[]
}

model Warehouse {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  inventoryItems InventoryItem[]
  movementsFrom  StockMovement[] @relation("FromWarehouse")
  movementsTo    StockMovement[] @relation("ToWarehouse")
  colectas       Colecta[]

  @@unique([name, organizationId])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  name           String
  role           String       @default("USER_MP") // "ADMIN_GI" | "USER_MP"
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  movements     StockMovement[]
  colectas      Colecta[]
  colectaAvisos ColectaAviso[]
}

model Product {
  id             String       @id @default(uuid())
  name           String
  sku            String?
  unit           String       @default("pza")
  description    String?
  price          Decimal?     @db.Decimal(10, 2)
  cost           Decimal?     @db.Decimal(10, 2)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  inventoryItems InventoryItem[]
  movements      StockMovement[]
  colectaItems   ColectaItem[]

  @@index([organizationId])
}

model InventoryItem {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id              String     @id @default(uuid())
  type            String     // "ENTRY" | "EXIT" | "TRANSFER" | "RETURN"
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  quantity        Int
  reason          String?
  notes           String?
  receiverName    String?
  createdById     String
  createdBy       User       @relation(fields: [createdById], references: [id])
  createdAt       DateTime   @default(now())

  @@index([productId])
  @@index([createdById])
  @@index([createdAt])
}

model Colecta {
  id              String   @id @default(uuid())
  folio           String
  ordenCompra     String?
  numeroColecta   String?
  numeroSolicitud String?
  metodoEntrega   String   @default("RETIRO_FULL")
  status          String   @default("CREADA")
  clienteNombre   String?

  tallerArrivedAt DateTime?
  prepDeadlineAt  DateTime?
  readyAt         DateTime?
  collectedAt     DateTime?

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?   @relation(fields: [warehouseId], references: [id])
  createdById     String
  createdBy       User         @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items  ColectaItem[]
  avisos ColectaAviso[]

  @@unique([folio, organizationId])
  @@index([organizationId])
  @@index([status])
}

model ColectaItem {
  id         String  @id @default(uuid())
  colectaId  String
  colecta    Colecta @relation(fields: [colectaId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  kitGroupId String? // piezas del mismo kit comparten este id (null = pieza suelta)
  kitLabel   String? // etiqueta del kit, p. ej. "Kit — Playera Hombre Grande"

  @@index([colectaId])
  @@index([kitGroupId])
}

model ColectaAviso {
  id          String   @id @default(uuid())
  colectaId   String
  colecta     Colecta  @relation(fields: [colectaId], references: [id], onDelete: Cascade)
  tipo        String
  mensaje     String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([colectaId])
}
